<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox is intentionally DISABLED. A sandboxed app gets a
	     redirected $TMPDIR and cannot find Discord's IPC socket, and it
	     cannot read ~/.claude/projects/. Do not enable this. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
