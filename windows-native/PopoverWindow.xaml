<Window x:Class="AgentCord.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="agentcord"
        Width="330" SizeToContent="Height"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False" Topmost="True"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI" TextElement.Foreground="{DynamicResource TextBrush}"
        Deactivated="OnDeactivated" KeyDown="OnKeyDown" SizeChanged="OnSizeChanged"
        Closing="OnClosing">

  <Window.Resources>
    <!-- Fixed light palette pulled from the macOS popover design. -->
    <SolidColorBrush x:Key="TextBrush" Color="#FF1D1D1F"/>
    <SolidColorBrush x:Key="SecStrong" Color="#B33C3C43"/>
    <SolidColorBrush x:Key="SecMid" Color="#8C3C3C43"/>
    <SolidColorBrush x:Key="SecSoft" Color="#663C3C43"/>

    <!-- White card with a hairline border (session + usage cards). -->
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="BorderBrush" Value="#0F000000"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="12,11"/>
    </Style>

    <!-- Translucent card (collapsible sections, nav rows). -->
    <Style x:Key="CardSoft" TargetType="Border">
      <Setter Property="Background" Value="#8CFFFFFF"/>
      <Setter Property="CornerRadius" Value="9"/>
      <Setter Property="BorderBrush" Value="#12000000"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Chromeless button used for clickable rows. -->
    <Style x:Key="PlainRow" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="9">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Small bordered chip (the activity-type cycle button). -->
    <Style x:Key="Chip" TargetType="Button">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="#1A787880" CornerRadius="6"
                    BorderBrush="#1F000000" BorderThickness="1" Padding="7,3">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- iOS-style toggle switch (28x17, green when on). -->
    <Style x:Key="Switch" TargetType="ToggleButton">
      <Setter Property="Width" Value="28"/>
      <Setter Property="Height" Value="17"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Track" CornerRadius="8.5" Background="#3D787880">
              <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="White"
                       HorizontalAlignment="Left" Margin="1.5,0">
                <Ellipse.Effect>
                  <DropShadowEffect BlurRadius="1.5" ShadowDepth="0.5" Opacity="0.3"/>
                </Ellipse.Effect>
              </Ellipse>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Track" Property="Background" Value="#FF34C759"/>
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Windows 11 ships Segoe Fluent Icons (its E8B7 is a real folder); Windows
         10 only has Segoe MDL2 Assets, so fall back to it. -->
    <Style x:Key="Glyph" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <!-- Outer margin leaves room for the drop shadow. -->
  <Border Margin="10" CornerRadius="12" Background="#FFF2F2F5"
          BorderBrush="#26000000" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.30"/>
    </Border.Effect>
    <Grid Margin="13">

      <!-- ============================ Main screen ============================ -->
      <StackPanel x:Name="MainScreen">

        <!-- Header: logo, title, connection pill -->
        <DockPanel Margin="0,0,0,11">
          <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="7">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF3A3A3C" Offset="0"/>
                <GradientStop Color="#FF1B1B1D" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="&#x2726;" Foreground="White" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <Border x:Name="StatusPill" DockPanel.Dock="Right" CornerRadius="9"
                  Padding="6,2,8,2" VerticalAlignment="Center" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
              <Ellipse x:Name="StatusPillDot" Width="6" Height="6" VerticalAlignment="Center"/>
              <TextBlock x:Name="StatusPillText" FontSize="11" FontWeight="Medium" Margin="5,0,0,0"/>
            </StackPanel>
          </Border>
          <TextBlock Text="agentcord" FontSize="15" FontWeight="SemiBold"
                     VerticalAlignment="Center" Margin="9,0,0,0"/>
        </DockPanel>

        <!-- Active session card -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,11">
          <StackPanel>
            <DockPanel>
              <Border DockPanel.Dock="Right" Background="#1A787880" CornerRadius="9" Padding="7,2,8,2">
                <StackPanel Orientation="Horizontal">
                  <Ellipse x:Name="SessionDot" Width="6" Height="6" VerticalAlignment="Center"/>
                  <!-- Tabular figures keep the ticking clock from jittering. -->
                  <TextBlock x:Name="ElapsedText" FontSize="11.5" FontWeight="Medium" Margin="5,0,0,0"
                             Typography.NumeralAlignment="Tabular"/>
                </StackPanel>
              </Border>
              <TextBlock Text="ACTIVE SESSION" FontSize="11" FontWeight="SemiBold"
                         Foreground="{StaticResource SecMid}" VerticalAlignment="Center"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
              <TextBlock Style="{StaticResource Glyph}" Text="&#xE8B7;" FontSize="12"
                         Foreground="{StaticResource SecMid}"/>
              <TextBlock x:Name="ProjectText" FontSize="13.5" FontWeight="SemiBold" Margin="7,0,0,0"/>
            </StackPanel>
            <TextBlock x:Name="MetaText" FontSize="12.5" Margin="21,4,0,0"/>
            <Border BorderBrush="#0F000000" BorderThickness="0,1,0,0" Margin="0,9,0,0" Padding="0,8,0,0">
              <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="BroadcastDot" Width="5" Height="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="BroadcastText" FontSize="11"
                           Foreground="{StaticResource SecMid}" Margin="6,0,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Usage card -->
        <Border Style="{StaticResource Card}" Margin="0,0,0,11">
          <StackPanel>
            <TextBlock Text="USAGE" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SecMid}"/>
            <StackPanel x:Name="UsageRows" Margin="0,10,0,-10"/>
            <TextBlock x:Name="ErrorText" FontSize="11" Foreground="#FFFF3B30"
                       TextWrapping="Wrap" Visibility="Collapsed" Margin="0,10,0,0"/>
          </StackPanel>
        </Border>

        <!-- Claude status card (hidden until the first successful fetch) -->
        <Border x:Name="StatusCard" Style="{StaticResource CardSoft}" Margin="0,0,0,11"
                Visibility="Collapsed">
          <StackPanel>
            <Button Style="{StaticResource PlainRow}" Click="OnToggleStatus">
              <DockPanel Margin="11,8">
                <TextBlock x:Name="StatusChevron" DockPanel.Dock="Right" Style="{StaticResource Glyph}"
                           Text="&#xE76C;" FontSize="10" Foreground="{StaticResource SecSoft}"
                           Margin="6,0,0,0" Width="10" TextAlignment="Center"/>
                <Border x:Name="ClaudePill" DockPanel.Dock="Right" CornerRadius="9"
                        Padding="6,2,8,2" VerticalAlignment="Center" BorderThickness="1">
                  <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ClaudePillDot" Width="6" Height="6" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ClaudePillText" FontSize="11" FontWeight="Medium" Margin="5,0,0,0"/>
                  </StackPanel>
                </Border>
                <TextBlock Text="Claude status" FontSize="13" VerticalAlignment="Center"/>
              </DockPanel>
            </Button>
            <StackPanel x:Name="StatusExpanded" Visibility="Collapsed" Margin="11,1,11,10">
              <StackPanel x:Name="IncidentsPanel"/>
              <StackPanel x:Name="ComponentsPanel"/>
              <Button Style="{StaticResource PlainRow}" Click="OnOpenStatusPage" Margin="0,8,0,0">
                <DockPanel>
                  <TextBlock DockPanel.Dock="Right" Style="{StaticResource Glyph}" Text="&#xE8A7;"
                             FontSize="10" Foreground="{StaticResource SecSoft}"/>
                  <TextBlock x:Name="StatusFooterText" FontSize="11" Foreground="{StaticResource SecMid}"/>
                </DockPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Settings nav row -->
        <Border Style="{StaticResource CardSoft}" Margin="0,0,0,11">
          <Button Style="{StaticResource PlainRow}" Click="OnOpenSettings">
            <DockPanel Margin="11,8">
              <TextBlock DockPanel.Dock="Left" Style="{StaticResource Glyph}" Text="&#xE713;"
                         FontSize="13" Foreground="{StaticResource SecStrong}"/>
              <TextBlock DockPanel.Dock="Right" Style="{StaticResource Glyph}" Text="&#xE76C;"
                         FontSize="10" Foreground="{StaticResource SecSoft}" Margin="6,0,0,0"/>
              <TextBlock x:Name="SettingsSummary" DockPanel.Dock="Right" FontSize="12"
                         Foreground="{StaticResource SecSoft}" VerticalAlignment="Center"/>
              <TextBlock Text="Settings" FontSize="13" VerticalAlignment="Center" Margin="7,0,0,0"/>
            </DockPanel>
          </Button>
        </Border>

        <Rectangle Height="1" Fill="#14000000" Margin="0,0,0,11"/>

        <!-- Quit -->
        <Border Background="#A6FFFFFF" CornerRadius="7" BorderBrush="#1A000000" BorderThickness="1">
          <Button Style="{StaticResource PlainRow}" Click="OnQuit">
            <DockPanel Margin="11,6">
              <TextBlock DockPanel.Dock="Right" Text="Alt+F4" FontSize="12"
                         Foreground="{StaticResource SecSoft}" VerticalAlignment="Center"/>
              <TextBlock Text="Quit agentcord" FontSize="13" VerticalAlignment="Center"/>
            </DockPanel>
          </Button>
        </Border>
      </StackPanel>

      <!-- ========================== Settings screen ========================== -->
      <StackPanel x:Name="SettingsScreen" Visibility="Collapsed">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
          <Button Style="{StaticResource PlainRow}" Click="OnCloseSettings">
            <Border Width="26" Height="26" CornerRadius="7" Background="#24787880">
              <TextBlock Style="{StaticResource Glyph}" Text="&#xE76B;" FontSize="12"
                         FontWeight="Bold" HorizontalAlignment="Center"/>
            </Border>
          </Button>
          <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold"
                     VerticalAlignment="Center" Margin="9,0,0,0"/>
        </StackPanel>

        <!-- Primary toggles -->
        <StackPanel Margin="0,0,0,11">
          <DockPanel Margin="0,6">
            <ToggleButton x:Name="PresenceSwitch" DockPanel.Dock="Right"
                          Style="{StaticResource Switch}" Click="OnPresenceSwitch"/>
            <TextBlock Text="Enable presence" FontSize="13" VerticalAlignment="Center"/>
          </DockPanel>
          <Rectangle Height="1" Fill="#0D000000"/>
          <DockPanel Margin="0,6">
            <ToggleButton x:Name="AutostartSwitch" DockPanel.Dock="Right"
                          Style="{StaticResource Switch}" Click="OnAutostartSwitch"/>
            <TextBlock Text="Launch at login" FontSize="13" VerticalAlignment="Center"/>
          </DockPanel>
          <Rectangle Height="1" Fill="#0D000000"/>
          <DockPanel Margin="0,6">
            <ToggleButton x:Name="PreventSleepSwitch" DockPanel.Dock="Right"
                          Style="{StaticResource Switch}" Click="OnPreventSleepSwitch"/>
            <TextBlock Text="Prevent sleep" FontSize="13" VerticalAlignment="Center"/>
          </DockPanel>
        </StackPanel>

        <!-- Display (collapsible) -->
        <Border Style="{StaticResource CardSoft}" Margin="0,0,0,7">
          <StackPanel>
            <Button Style="{StaticResource PlainRow}" Click="OnToggleDisplay">
              <DockPanel Margin="11,8">
                <TextBlock x:Name="DisplayChevron" DockPanel.Dock="Right" Style="{StaticResource Glyph}"
                           Text="&#xE76C;" FontSize="10" Foreground="{StaticResource SecSoft}"
                           Margin="6,0,0,0" Width="10" TextAlignment="Center"/>
                <TextBlock x:Name="DisplaySummary" DockPanel.Dock="Right" FontSize="12"
                           Foreground="{StaticResource SecSoft}" VerticalAlignment="Center"/>
                <TextBlock Text="Display" FontSize="13" VerticalAlignment="Center"/>
              </DockPanel>
            </Button>
            <StackPanel x:Name="DisplayExpanded" Visibility="Collapsed" Margin="11,1,11,8">
              <DockPanel Margin="0,5">
                <ToggleButton x:Name="ShowProjectSwitch" DockPanel.Dock="Right"
                              Style="{StaticResource Switch}" Click="OnShowProjectSwitch"/>
                <TextBlock Text="Show project" FontSize="12.5" VerticalAlignment="Center"/>
              </DockPanel>
              <Rectangle Height="1" Fill="#0D000000"/>
              <DockPanel Margin="0,5">
                <ToggleButton x:Name="ShowModelSwitch" DockPanel.Dock="Right"
                              Style="{StaticResource Switch}" Click="OnShowModelSwitch"/>
                <TextBlock Text="Show model" FontSize="12.5" VerticalAlignment="Center"/>
              </DockPanel>
              <Rectangle Height="1" Fill="#0D000000"/>
              <DockPanel Margin="0,5">
                <ToggleButton x:Name="ShowTokensSwitch" DockPanel.Dock="Right"
                              Style="{StaticResource Switch}" Click="OnShowTokensSwitch"/>
                <TextBlock Text="Show tokens" FontSize="12.5" VerticalAlignment="Center"/>
              </DockPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Activity & idle (collapsible) -->
        <Border Style="{StaticResource CardSoft}">
          <StackPanel>
            <Button Style="{StaticResource PlainRow}" Click="OnToggleActivity">
              <DockPanel Margin="11,8">
                <TextBlock x:Name="ActivityChevron" DockPanel.Dock="Right" Style="{StaticResource Glyph}"
                           Text="&#xE76C;" FontSize="10" Foreground="{StaticResource SecSoft}"
                           Margin="6,0,0,0" Width="10" TextAlignment="Center"/>
                <TextBlock x:Name="ActivitySummary" DockPanel.Dock="Right" FontSize="12"
                           Foreground="{StaticResource SecSoft}" VerticalAlignment="Center"/>
                <TextBlock Text="Activity &amp; idle" FontSize="13" VerticalAlignment="Center"/>
              </DockPanel>
            </Button>
            <StackPanel x:Name="ActivityExpanded" Visibility="Collapsed" Margin="11,4,11,10">
              <DockPanel>
                <Button x:Name="ActivityCycle" DockPanel.Dock="Right" Style="{StaticResource Chip}"
                        Click="OnCycleActivity">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ActivityLabel" FontSize="12.5"/>
                    <TextBlock Style="{StaticResource Glyph}" Text="&#xE70D;" FontSize="7"
                               Foreground="{StaticResource SecSoft}" Margin="6,0,0,0"/>
                  </StackPanel>
                </Button>
                <TextBlock Text="Activity type" FontSize="12.5" VerticalAlignment="Center"/>
              </DockPanel>
              <DockPanel Margin="0,10,0,0">
                <TextBlock x:Name="IdleValue" DockPanel.Dock="Right" FontSize="12.5"
                           Foreground="{StaticResource SecStrong}"/>
                <TextBlock Text="Idle window" FontSize="12.5"/>
              </DockPanel>
              <Slider x:Name="IdleSlider" Minimum="0" Maximum="5" TickFrequency="1"
                      IsSnapToTickEnabled="True" ValueChanged="OnIdleChanged" Margin="0,4,0,0"/>
              <UniformGrid Columns="6" Margin="2,1,2,0">
                <TextBlock Text="5" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Left"/>
                <TextBlock Text="10" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Center"/>
                <TextBlock Text="15" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Center"/>
                <TextBlock Text="20" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Center"/>
                <TextBlock Text="25" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Center"/>
                <TextBlock Text="30" FontSize="9.5" Foreground="{StaticResource SecSoft}" HorizontalAlignment="Right"/>
              </UniformGrid>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</Window>
