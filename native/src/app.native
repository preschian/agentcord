<!-- Portrait overview: a compact active session followed by three provider rows. -->
<column background="background" grow="1" padding="16" gap="10">

  <row height="32" gap="8" cross="center" window-drag="true">
    <image image="{app_icon_image}" width="28" height="28" label="AgentCord" />
    <text grow="1">agentcord</text>
    <button size="sm" variant="ghost" icon="refresh-cw" label="Refresh usage" on-press="refresh_usage" />
    <button size="sm" variant="ghost" icon="x" on-press="quit">Quit</button>
  </row>

  <!-- Unified Discord presence: intentionally compact, never a dashboard hero. -->
  <card height="96" padding="12" background="accent" radius="xl">
    <row grow="1" gap="10" cross="center">
      <avatar size="lg" image="{active_agent_image}" label="{active_agent_name}">{active_agent_initial}</avatar>
      <column grow="1" gap="2">
        <text foreground="accent_text">{session_title}</text>
        <text foreground="accent_text" wrap="true">{project_text}</text>
        <text foreground="accent_text" wrap="true">{active_agent_name} - {meta_text}</text>
      </column>
      <text foreground="accent_text">{elapsed_text}</text>
    </row>
  </card>

  <!-- Provider rows: every usage source stays visible in the portrait frame. -->
  <column gap="8">

    <card height="84" padding="10" background="surface" radius="xl">
      <column grow="1" gap="6">
        <row cross="center">
          <text grow="1">Codex</text>
          <text foreground="text_muted">Usage</text>
        </row>
        <separator />
        <column grow="1" gap="4">
          <if test="{codex_usage_has_data}">
            <column gap="4">
              <row cross="center">
                <text grow="1">{codex_primary_label_text}</text>
                <text foreground="text_muted">{codex_primary_text}</text>
              </row>
              <progress value="{codex_primary_frac}" label="Codex rate limit" />
            </column>
            <if test="{codex_secondary_len > 0}">
              <column gap="4">
                <row cross="center">
                  <text grow="1">{codex_secondary_label_text}</text>
                  <text foreground="text_muted">{codex_secondary_text}</text>
                </row>
                <progress value="{codex_secondary_frac}" label="Codex secondary rate limit" />
              </column>
            </if>
          </if>
          <else>
            <text foreground="text_muted" wrap="true">{codex_usage_status_text}</text>
          </else>
        </column>
      </column>
    </card>

    <card height="108" padding="10" background="surface" radius="xl">
      <column grow="1" gap="6">
        <row cross="center">
          <text grow="1">Cursor</text>
          <text foreground="text_muted">Usage</text>
        </row>
        <separator />
        <column grow="1" gap="4">
          <if test="{cursor_usage_has_data}">
            <column gap="4">
              <row cross="center">
                <text grow="1">Included</text>
                <text foreground="text_muted">{cursor_included_text}</text>
              </row>
              <progress value="{cursor_included_frac}" label="Cursor included usage" />
            </column>
            <if test="{cursor_auto_len > 0}">
              <column gap="4">
                <row cross="center">
                  <text grow="1">Auto</text>
                  <text foreground="text_muted">{cursor_auto_text}</text>
                </row>
                <progress value="{cursor_auto_frac}" label="Cursor Auto usage" />
              </column>
            </if>
          </if>
          <else>
            <text foreground="text_muted" wrap="true">{cursor_status_text}</text>
          </else>
        </column>
      </column>
    </card>

    <card height="84" padding="10" background="surface" radius="xl">
      <column grow="1" gap="6">
        <row cross="center">
          <text grow="1">Grok</text>
          <text foreground="text_muted">Usage</text>
        </row>
        <separator />
        <column grow="1" gap="4">
          <if test="{usage_has_data}">
            <column gap="4">
              <row cross="center">
                <text grow="1">Weekly credits</text>
                <text foreground="text_muted">{usage_weekly_text}</text>
              </row>
              <progress value="{usage_weekly_frac}" label="Grok weekly credits" />
            </column>
            <if test="{usage_ondemand_len > 0}">
              <column gap="4">
                <row cross="center">
                  <text grow="1">On-demand</text>
                  <text foreground="text_muted">{usage_ondemand_text}</text>
                </row>
                <progress value="{usage_ondemand_frac}" label="Grok on-demand usage" />
              </column>
            </if>
          </if>
          <else>
            <text foreground="text_muted" wrap="true">{usage_status_text}</text>
          </else>
        </column>
      </column>
    </card>

  </column>

  <spacer grow="1" />
</column>
